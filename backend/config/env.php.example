<?php
// Fly.io / Docker 環境では fly secrets set でこれらを設定してください

// SQLiteデータベースファイルのパス（永続ボリュームにマウントすること）
define('SQLITE_PATH',        getenv('SQLITE_PATH')    ?: '/data/oyako.db');

// JWT署名キー: php -r "echo bin2hex(random_bytes(32));" で生成
define('JWT_SECRET',         getenv('JWT_SECRET')     ?: 'your-secret-here');

define('JWT_TTL',            60 * 60 * 24 * 30); // 30日
define('SSE_TOKEN_TTL',      90);                 // SSE短命トークン有効期限（秒）

// フロントエンドのオリジン（例: https://your-app.fly.dev）
define('ALLOWED_ORIGIN',     getenv('ALLOWED_ORIGIN') ?: 'http://localhost');

define('LOGIN_MAX_ATTEMPTS', 10);
define('LOGIN_LOCKOUT_SEC',  300);

// アップロードファイル保存ディレクトリ（末尾スラッシュ必須・永続ボリューム推奨）
define('UPLOAD_DIR',         getenv('UPLOAD_DIR')     ?: '/data/uploads/');
define('MAX_UPLOAD_BYTES',   100 * 1024 * 1024);    // 100MB
